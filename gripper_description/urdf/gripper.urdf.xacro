<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="simple_gripper">

  <!-- ===================== -->
  <!-- Materials             -->
  <!-- ===================== -->
  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- ===================== -->
  <!-- Base Link             -->
  <!-- ===================== -->
  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.06 0.06 0.02"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.06 0.06 0.02"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.001" ixy="0.0" ixz="0.0"
        iyy="0.001" iyz="0.0"
        izz="0.001"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!-- Left Finger           -->
  <!-- ===================== -->
  <link name="left_finger">
    <visual>
      <geometry>
        <box size="0.01 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0.02 0"/>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.01 0.04 0.02"/>
      </geometry>
      <origin xyz="0 0.02 0"/>
      <surface>
        <friction>
          <ode>
            <mu>2.0</mu>
            <mu2>2.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0.02 0"/>
      <inertia
        ixx="0.0001" ixy="0.0" ixz="0.0"
        iyy="0.0001" iyz="0.0"
        izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!-- Right Finger          -->
  <!-- ===================== -->
  <link name="right_finger">
    <visual>
      <geometry>
        <box size="0.01 0.04 0.02"/>
      </geometry>
      <origin xyz="0 -0.02 0"/>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.01 0.04 0.02"/>
      </geometry>
      <origin xyz="0 -0.02 0"/>
      <surface>
        <friction>
          <ode>
            <mu>2.0</mu>
            <mu2>2.0</mu2>
          </ode>
        </friction>
      </surface>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 -0.02 0"/>
      <inertia
        ixx="0.0001" ixy="0.0" ixz="0.0"
        iyy="0.0001" iyz="0.0"
        izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!-- Joints (Prismatic)    -->
  <!-- ===================== -->

  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0 0.03 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.02" effort="20" velocity="0.1"/>
  </joint>

  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0 -0.03 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.02" effort="20" velocity="0.1"/>
  </joint>

  <!-- ===================== -->
  <!-- ros2_control Block    -->
  <!-- ===================== -->

<ros2_control name="IgnitionSystem" type="system">
  <hardware>
    <plugin>ign_ros2_control/IgnitionSystem</plugin>
  </hardware>

  <joint name="left_finger_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
  </joint>

  <joint name="right_finger_joint">
    <command_interface name="position"/>
    <state_interface name="position"/>
  </joint>
</ros2_control>

<gazebo>
  <plugin filename="libign_ros2_control-system.so"
          name="/home/rafie/Vision-Heroes-2026-test-mecanum/gripper/install/gripper_description/share/gripper_description/config/controllers.yaml"/>
</gazebo>

</robot>
